# --- Routing ---
# PROVIDER may be a single name OR a comma-separated fallback chain.
# E.g. PROVIDER=cloudflare,openrouter  -> try Cloudflare first, OpenRouter on 5xx/network error.
# Valid: cloudflare, nvidia, openrouter, deepseek, lmstudio, llamacpp, ollama
PROVIDER=cloudflare

# Per-tier overrides — same syntax as PROVIDER. Falls back to PROVIDER if unset.
ROUTE_OPUS=
ROUTE_SONNET=
ROUTE_HAIKU=

# Override default upstream models (optional)
# BIG_MODEL is used for opus/sonnet, SMALL_MODEL for haiku.
BIG_MODEL=
SMALL_MODEL=

# --- Server ---
PORT=3000

# Optional shared secret. If set, clients must send it as ANTHROPIC_AUTH_TOKEN.
AUTH_TOKEN=

# Append every request to logs/requests.jsonl
LOG_REQUESTS=false

# Cache non-streaming responses on disk for N seconds (0 disables)
CACHE_TTL=0

# --- Cloudflare Workers AI ---
# CLOUDFLARE_API_TOKEN may be a comma-separated list for round-robin rotation.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# --- NVIDIA NIM ---
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# --- OpenRouter ---
OPENROUTER_API_KEY=

# --- DeepSeek ---
DEEPSEEK_API_KEY=

# --- LM Studio (local) ---
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model

# --- llama.cpp (local) ---
LLAMACPP_BASE_URL=http://localhost:8080/v1
LLAMACPP_MODEL=local-model

# --- Ollama (local) ---
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1

# --- Bots (optional) ---
# Used by bots/telegram.js and bots/discord.js, not by the proxy itself.
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
PROXY_URL=http://localhost:3000
ANTHROPIC_AUTH_TOKEN=
BOT_MODEL=claude-3-5-sonnet-20241022
